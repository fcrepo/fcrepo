<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
    http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
    http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-3.0.xsd">

    <context:annotation-config/>

    <bean id="jmsBroker"
          class="org.apache.activemq.artemis.core.server.embedded.EmbeddedActiveMQ"
          init-method="start"
          destroy-method="stop">
        <property name="configResourcePath" value="file:src/test/resources/spring-test/broker-queue.xml"/>
    </bean>

    <bean id="connectionFactory"
          class="org.apache.activemq.artemis.jms.client.ActiveMQConnectionFactory"
          depends-on="jmsBroker">
        <constructor-arg value="tcp://localhost:61616"/>
    </bean>

    <bean class="org.fcrepo.jms.JMSQueuePublisher" depends-on="jmsBroker">
        <constructor-arg type="java.lang.String" value="/fedora"/>
    </bean>

    <bean class="org.fcrepo.jms.DefaultMessageFactory"/>

</beans>